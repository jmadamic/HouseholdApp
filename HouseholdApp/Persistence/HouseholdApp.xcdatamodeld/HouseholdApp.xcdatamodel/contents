<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<model type="com.apple.IDECoreDataModeler.DataModel" documentVersion="1.0" lastSavedToolsVersion="22222" systemVersion="22A380" minimumToolsVersion="Automatic" sourceLanguage="Swift" userDefinedModelVersionIdentifier="">
    <!--
        HouseholdApp Core Data Model
        ─────────────────────────
        All attributes are marked optional=YES as required by CloudKit.
        Non-nil enforcement happens in the Swift layer (see CoreDataHelpers.swift).
        No ordered relationships — CloudKit does not support NSOrderedSet.
        Use sortOrder (Integer 32) for manual ordering instead.
    -->

    <!-- ══════════════════════════════════════════════════════
         Category — a named bucket for grouping chores
         (e.g. Kitchen, Bathroom, Laundry)
    ══════════════════════════════════════════════════════ -->
    <entity name="Category" representedClassName="Category" syncable="YES" codeGenerationType="class">
        <!-- Primary key — always set on creation -->
        <attribute name="id"        optional="YES" attributeType="UUID"       usesScalarValueType="NO"/>
        <!-- Display name shown in UI -->
        <attribute name="name"      optional="YES" attributeType="String"/>
        <!-- Hex color string e.g. "#FF6B6B" -->
        <attribute name="colorHex"  optional="YES" attributeType="String"/>
        <!-- SF Symbol name e.g. "fork.knife" -->
        <attribute name="iconName"  optional="YES" attributeType="String"/>
        <!-- Used for manual sort order in lists -->
        <attribute name="sortOrder" optional="YES" attributeType="Integer 32" defaultValueString="0" usesScalarValueType="YES"/>

        <!-- One category has many chores; deleting a category nullifies the
             chore's category reference (chores are not deleted with the category) -->
        <relationship name="chores" optional="YES" toMany="YES" deletionRule="Nullify"
                      destinationEntity="Chore" inverseName="category" inverseEntity="Chore"/>
    </entity>

    <!-- ══════════════════════════════════════════════════════
         Chore — a single household task
    ══════════════════════════════════════════════════════ -->
    <entity name="Chore" representedClassName="Chore" syncable="YES" codeGenerationType="class">
        <!-- Primary key -->
        <attribute name="id"                optional="YES" attributeType="UUID"       usesScalarValueType="NO"/>
        <!-- Short description of the chore -->
        <attribute name="title"             optional="YES" attributeType="String"/>
        <!-- Optional longer description -->
        <attribute name="notes"             optional="YES" attributeType="String"/>

        <!-- Who should do it: -1=Everyone  0+=member index
             See MemberAssignment.swift -->
        <attribute name="assignedTo"        optional="YES" attributeType="Integer 16" defaultValueString="-1" usesScalarValueType="YES"/>

        <!-- Due date type: 0=specificDate  1=thisWeek  2=thisMonth  3=none
             See Enums.swift → DueDateType -->
        <attribute name="dueDateType"       optional="YES" attributeType="Integer 16" defaultValueString="3" usesScalarValueType="YES"/>
        <!-- Only populated when dueDateType == .specificDate -->
        <attribute name="dueDate"           optional="YES" attributeType="Date"       usesScalarValueType="NO"/>

        <!-- Repeat cadence: 0=none  1=daily  2=weekly  3=biweekly  4=monthly  5=yearly
             See Enums.swift → RepeatInterval
             When a chore is marked complete and repeatInterval != none,
             the chore is reset with a new dueDate rather than being archived. -->
        <attribute name="repeatInterval"    optional="YES" attributeType="Integer 16" defaultValueString="0" usesScalarValueType="YES"/>

        <!-- Completion state -->
        <attribute name="isCompleted"       optional="YES" attributeType="Boolean"    defaultValueString="NO" usesScalarValueType="YES"/>
        <attribute name="completedAt"       optional="YES" attributeType="Date"       usesScalarValueType="NO"/>
        <!-- Track which person(s) completed — useful for "Everyone" chores.
             Legacy booleans kept for backward compat; new field is preferred. -->
        <attribute name="completedByMe"      optional="YES" attributeType="Boolean"   defaultValueString="NO" usesScalarValueType="YES"/>
        <attribute name="completedByPartner" optional="YES" attributeType="Boolean"   defaultValueString="NO" usesScalarValueType="YES"/>
        <!-- Comma-separated member indices who completed, e.g. "0,2" -->
        <attribute name="completedByMembers" optional="YES" attributeType="String"/>

        <!-- Timestamps -->
        <attribute name="createdAt"         optional="YES" attributeType="Date"       usesScalarValueType="NO"/>
        <!-- Manual sort order for list display -->
        <attribute name="sortOrder"         optional="YES" attributeType="Integer 32" defaultValueString="0" usesScalarValueType="YES"/>

        <!-- Many-to-one: category (nullable — uncategorized chores are allowed) -->
        <relationship name="category"       optional="YES" maxCount="1" deletionRule="Nullify"
                      destinationEntity="Category" inverseName="chores" inverseEntity="Category"/>
        <!-- One-to-many: completion history (cascade delete with the chore) -->
        <relationship name="completionLogs" optional="YES" toMany="YES" deletionRule="Cascade"
                      destinationEntity="CompletionLog" inverseName="chore" inverseEntity="CompletionLog"/>
    </entity>

    <!-- ══════════════════════════════════════════════════════
         CompletionLog — one record per time a chore was completed.
         Enables history, streaks, and per-person stats.
    ══════════════════════════════════════════════════════ -->
    <entity name="CompletionLog" representedClassName="CompletionLog" syncable="YES" codeGenerationType="class">
        <attribute name="id"          optional="YES" attributeType="UUID"       usesScalarValueType="NO"/>
        <attribute name="completedAt" optional="YES" attributeType="Date"       usesScalarValueType="NO"/>
        <!-- 0=Me  1=Partner  (matches AssignedTo.me / .partner raw values) -->
        <attribute name="completedBy" optional="YES" attributeType="Integer 16" defaultValueString="0" usesScalarValueType="YES"/>

        <!-- Many-to-one back to the parent chore -->
        <relationship name="chore"    optional="YES" maxCount="1" deletionRule="Nullify"
                      destinationEntity="Chore" inverseName="completionLogs" inverseEntity="Chore"/>
    </entity>

    <!-- ══════════════════════════════════════════════════════
         ShoppingItem — a single item on the shopping list.
         Categorized by type (Food, Furniture, Maintenance, etc.)
         and by store (Costco, Target, Home Depot, etc.).
         Both type and store are freeform strings — new values
         are added from the form picker and persisted in UserDefaults.
    ══════════════════════════════════════════════════════ -->
    <entity name="ShoppingItem" representedClassName="ShoppingItem" syncable="YES" codeGenerationType="class">
        <attribute name="id"          optional="YES" attributeType="UUID"       usesScalarValueType="NO"/>
        <!-- Item name e.g. "Paper Towels" -->
        <attribute name="name"        optional="YES" attributeType="String"/>
        <!-- Freeform quantity e.g. "2", "1 lb", "6-pack" -->
        <attribute name="quantity"    optional="YES" attributeType="String"/>
        <!-- Store name e.g. "Costco" — nil means no specific store -->
        <attribute name="store"       optional="YES" attributeType="String"/>
        <!-- Item type e.g. "Food", "Furniture" — nil means uncategorized -->
        <attribute name="itemType"    optional="YES" attributeType="String"/>
        <!-- Who should buy it: 0=Me  1=Partner  2=Both -->
        <attribute name="assignedTo"  optional="YES" attributeType="Integer 16" defaultValueString="0" usesScalarValueType="YES"/>
        <!-- Checked off? -->
        <attribute name="isPurchased" optional="YES" attributeType="Boolean"    defaultValueString="NO" usesScalarValueType="YES"/>
        <attribute name="purchasedAt" optional="YES" attributeType="Date"       usesScalarValueType="NO"/>
        <attribute name="createdAt"   optional="YES" attributeType="Date"       usesScalarValueType="NO"/>
        <attribute name="sortOrder"   optional="YES" attributeType="Integer 32" defaultValueString="0" usesScalarValueType="YES"/>
        <attribute name="notes"       optional="YES" attributeType="String"/>
    </entity>
</model>
