// Firestore Security Rules for HouseholdApp
//
// Paste this into the Firebase Console:
//   Build → Firestore Database → Rules → paste → Publish
//
// Access model:
//  - A user may read/write documents inside a household only if their UID
//    is listed in that household's memberIds array.
//  - Anyone signed in can read an invite code (to look up the household ID
//    when joining) but only members of the household can delete/rotate it.
//  - A user can always create their first household (must include themselves
//    as the sole member and ownerId).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the signed-in user a member of the given household?
    function isMember(householdId) {
      return request.auth != null &&
             request.auth.uid in
               get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // ── households/{id} ────────────────────────────────────────────────────
    match /households/{householdId} {
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.memberIds;

      // Creating a household: the caller must be signed in, include themselves
      // as the sole member, and set themselves as the owner.
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.memberIds.size() == 1 &&
                       request.resource.data.memberIds[0] == request.auth.uid;

      // Updates: members may update. Joining (arrayUnion on memberIds) is
      // allowed for any signed-in user — the invite flow will have verified
      // the code before calling this.
      allow update: if request.auth != null && (
                       request.auth.uid in resource.data.memberIds ||
                       // Allow self-join: adding only yourself to memberIds.
                       (request.resource.data.memberIds.size() ==
                          resource.data.memberIds.size() + 1 &&
                        request.auth.uid in request.resource.data.memberIds)
                    );

      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.ownerId;

      // Subcollections: chores, categories, completions, shoppingItems
      match /chores/{choreId} {
        allow read, write: if isMember(householdId);
      }
      match /categories/{categoryId} {
        allow read, write: if isMember(householdId);
      }
      match /completions/{logId} {
        allow read, write: if isMember(householdId);
      }
      match /shoppingItems/{itemId} {
        allow read, write: if isMember(householdId);
      }
    }

    // ── invites/{code} ─────────────────────────────────────────────────────
    // Any signed-in user can look up an invite code (to find the household).
    // Only the household's members can create or delete invites.
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null &&
                               isMember(request.resource.data.householdId);
      allow update: if false;
    }
  }
}
